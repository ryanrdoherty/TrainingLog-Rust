{
  "title": "Sports Log",
  "uid": "sports-log",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(axum_http_requests_total[1m])) by (method, endpoint)",
          "legendFormat": "{{method}} {{endpoint}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Request Latency p50 / p95 / p99 (ms)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(axum_http_requests_duration_seconds_bucket[1m])) by (le)) * 1000",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(axum_http_requests_duration_seconds_bucket[1m])) by (le)) * 1000",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(axum_http_requests_duration_seconds_bucket[1m])) by (le)) * 1000",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 3,
      "title": "HTTP Error Rate (4xx / 5xx)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(axum_http_requests_total{status=~\"4..\"}[1m]))",
          "legendFormat": "4xx"
        },
        {
          "expr": "sum(rate(axum_http_requests_total{status=~\"5..\"}[1m]))",
          "legendFormat": "5xx"
        }
      ]
    },
    {
      "id": 4,
      "title": "New User Registrations (total)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 8, "w": 6, "h": 8 },
      "targets": [
        {
          "expr": "sports_log_users_registered_total",
          "legendFormat": "Registered"
        }
      ]
    },
    {
      "id": 5,
      "title": "Logins by Method",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(sports_log_logins_total{status=\"success\"}[5m])) by (method)",
          "legendFormat": "{{method}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Login Failures by Method",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(sports_log_logins_total{status=\"failure\"}[5m])) by (method)",
          "legendFormat": "{{method}} failures"
        }
      ]
    },
    {
      "id": 7,
      "title": "Activities Created (total)",
      "type": "stat",
      "gridPos": { "x": 18, "y": 8, "w": 6, "h": 8 },
      "targets": [
        {
          "expr": "sports_log_activities_created_total",
          "legendFormat": "Activities"
        }
      ]
    },
    {
      "id": 8,
      "title": "Process Memory (RSS)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "process_resident_memory_bytes",
          "legendFormat": "RSS bytes"
        }
      ]
    },
    {
      "id": 9,
      "title": "Process Threads",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 24, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "process_threads",
          "legendFormat": "Threads"
        }
      ]
    },
    {
      "id": 10,
      "title": "CPU Usage",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 32, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(process_cpu_seconds_total[1m])",
          "legendFormat": "CPU seconds/s"
        }
      ]
    },
    {
      "id": 11,
      "title": "DB Pool — Active Connections",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 32, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sqlx_pool_connections_active",
          "legendFormat": "Active"
        },
        {
          "expr": "sqlx_pool_connections_idle",
          "legendFormat": "Idle"
        }
      ]
    }
  ]
}
